# Copy this file to ".env" (same folder) and fill in values.
# Keep ".env" private; it is ignored by git via ".cursor/.gitignore".

VR_TOKEN=
VR_WALLET_ADDRESS=0x0000000000000000000000000000000000000000

# Telegram alert when Varibot hits VariAuthError on GET /api/portfolio (expired VR_TOKEN).
# Option A — custom webhook (POST JSON {"text": "..."}):
# TELEGRAM_WEBHOOK_URL=https://your-bridge.example/notify
# Option B — Telegram Bot API directly:
# TELEGRAM_BOT_TOKEN=123456:ABC...
# TELEGRAM_CHAT_ID=123456789
# TELEGRAM_AUTH_ALERT_COOLDOWN_S=1800
# Optional override; Render sets RENDER_SERVICE_NAME / RENDER_GIT_BRANCH automatically.
# VARIBOT_NOTIFY_DEPLOYMENT_NAME=Gridbot

# Cloud hosts (Railway, AWS, etc.) often get Cloudflare 403 HTML from omni.variational.io.
# Use a residential/datacenter proxy Cloudflare accepts, e.g. Bright Data, Oxylabs, etc.:
# HTTPS_PROXY=https://user:pass@host:port

# Bot configuration
BOT_MODE=paper
BOT_POLL_INTERVAL_S=300
MAX_SLIPPAGE=0.002
# Optional per-asset override (fraction). Example: allow LIGHTER up to 0.15% while keeping default lower.
# MAX_SLIPPAGE_LIGHTER=0.0015
MAX_LEVERAGE=50
DEFAULT_LEVERAGE=20

# Optional: path to a Python script that reads JSON stdin and prints JSON stdout.
# Example: variationalbot/signals/example_signal_script.py
BOT_SIGNAL_SCRIPT=
BOT_SIGNAL_TIMEOUT_S=120

# Storage
BOT_RUNS_DIR=./runs
BOT_STATE_DB=./state.db

# Gridstrat: ignore manual/pre-open venue positions; always use flat fresh-book path (default on)
# GRIDSTRAT_IGNORE_VENUE_POSITIONS=0

# Grid marks: one GET /api/metadata/supported_assets (default) vs per-ticker indicative quotes
# VARIBOT_MARKS_SOURCE=supported_assets
# VARIBOT_MARKS_SOURCE=indicative
# Live remnant: fresh indicative mark per ticker before posting limits (default on)
# VARIBOT_GRID_LIMITS_MARK_INDICATIVE=0

# Pending limits: one paginated GET /api/orders/v2?status=pending per cycle (default)
# VARIBOT_PENDING_BULK=0
# VARIBOT_PENDING_BULK_MAX_PAGES=6

# Interval risk rebalance (varibot one_cycle + rebalance_run.py)
# VARIBOT_REBALANCE_IM_TRIGGER=0.80   # default 80% initial margin (IM) usage
# VARIBOT_REBALANCE_MM_TRIGGER=0.80   # deprecated alias for IM trigger
# VARIBOT_REBALANCE_TRIM_MULTIPLE=0   # default off — per-ticker reduce-only trim (e.g. 15 = 15× rung)
# VARIBOT_REBALANCE_TRIM_FRACTION=0.5 # fraction of position qty per trim when enabled
# VARIBOT_POSITION_NOTIONAL_CAP_TRIM_MULTIPLE=30  # trim when notional > multiple × grid rung (30×400=$12k)
# VARIBOT_POSITION_NOTIONAL_CAP_TRIM_FRACTION=0.5 # reduce-only market trim fraction (50%)
# VARIBOT_POSITION_NOTIONAL_CAP_TRIM_MULTIPLE=0   # set 0 to disable notional-cap trim
# BTC/ETH/SOL book-hedge legs are excluded from all grid-style trims (see book_hedge.py)
# VARIBOT_BOOK_HEDGE_ENABLED=0          # default off — set 1 to enable book-direction hedge

# Ticker pain pause (grid): if uPnL+rPnL < -(frac × position value) → cancel limits, flatten, pause
# VARIBOT_TICKER_PAUSE_ENABLED=0        # default on when unset
# VARIBOT_TICKER_PAUSE_PNL_FRAC=0.05    # 5% of |position value|
# VARIBOT_TICKER_PAUSE_MIN_VALUE_USD=50
# VARIBOT_TICKER_PAUSE_CLEAR=NEAR,JUP   # or ALL — remove pause entries (.varibot_ticker_pause.json)
# VARIBOT_REBALANCE_IM_TARGET=0.20    # target notional sizing (IM fraction in formula)

# Grid limit ladder (paired_limit / gridstrat live)
# VARIBOT_GRID_LIMITS_RECONCILE=0          # default ON when unset — post missing limits; paired_limit re-arms on venue
# VARIBOT_GRID_LIMITS_DRIFT_RECONCILE=1    # optional explicit; auto-on when reconcile+paired_limit
# VARIBOT_GRID_LIMITS_DRIFT_CANCEL=0       # default ON — cancel limits beyond keep-depth (see CANCEL_ALL_* pacing)
# CANCEL_ALL_SLEEP_BETWEEN_S=1.5           # seconds between successful cancels (grid drift + cancelalllimitorders)
# CANCEL_ALL_MAX_RETRIES=12
# CANCEL_ALL_BAN_BUFFER_S=0.75
# CANCEL_ALL_PASSES=2
# GRIDSTRAT_FLAT_REBALANCE=1             # default off — set 1 to re-center full ladder at mark each cycle
# VARIBOT_GRID_LIMITS_DRIFT_REFILL=0       # optional: disable refill leg only
# VARIBOT_GRID_LIMITS_RECONCILE_WITH_POSITIONS=1  # legacy refill while positioned (drift implies this)
# VARIBOT_GRID_LIMITS_CANCEL_SLEEP_S=0.2

