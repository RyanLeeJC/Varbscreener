// This Pine Script™ code is subject to the terms of the Mozilla Public License 2.0 at https://mozilla.org/MPL/2.0/
// Grid vol_ratio — matches Varibot grid_vol_pause.py (realized σ / median baseline)
//
// Paste into TradingView → Pine Editor → Add to chart (separate pane).
// Works on any timeframe: lookbacks are in HOURS, not fixed bar counts.
//   5m chart  → 36-bar σ window, 72-bar median  (3h / 6h)
//   1m chart  → 180-bar σ window, 360-bar median
//   15m chart → 12-bar σ window, 24-bar median

//@version=5
indicator("Grid Vol Ratio (bot-aligned)", shorttitle="Grid VolRatio", overlay=false, max_bars_back=5000)

// ── Inputs (defaults match GRID_VOL_PAUSE_* env) ─────────────────────────────
volWindowHours   = input.float(3.0,  "σ window (hours)", minval=0.5, step=0.5,
     tooltip="Realized-vol window. Bot: 36×5m bars = 3 hours.")
medWindowHours   = input.float(6.0,  "Median baseline (hours)", minval=1.0, step=1.0,
     tooltip="Median of σ over this lookback. Bot: 72×5m bars = 6 hours.")
pauseRatio       = input.float(1.3,  "Pause threshold (vol_ratio)", minval=1.0, step=0.1,
     tooltip="GRID_VOL_PAUSE_VOL_RATIO")
resumeRatio      = input.float(1.3,  "Resume threshold", minval=1.0, step=0.1,
     tooltip="GRID_VOL_PAUSE_RESUME_VOL_RATIO")
cooldownHours    = input.float(1.0,  "Min pause cooldown (hours)", minval=0.25, step=0.25,
     tooltip="Stay paused at least this long after first trip. Bot: GRID_VOL_PAUSE_MIN_PAUSE_HOURS=1")
showGuides       = input.bool(true,   "Show pause / resume lines")
showBg           = input.bool(true,   "Highlight latched pause zone")
showInfo         = input.bool(true,   "Show bar counts (bottom-right)")

// ── Timeframe-adaptive bar lengths ───────────────────────────────────────────
secsPerBar = timeframe.in_seconds()
volLb      = math.max(2, int(math.round(volWindowHours * 3600.0 / secsPerBar)))
medLb      = math.max(volLb + 1, int(math.round(medWindowHours * 3600.0 / secsPerBar)))
cooldownBars = math.max(1, int(math.round(cooldownHours * 3600.0 / secsPerBar)))

// ── Realized vol ratio (study / bot formula) ─────────────────────────────────
lr     = math.log(close / close[1])
volNow = ta.stdev(lr, volLb)
volMed = ta.percentile_linear_interpolation(volNow, medLb, 50)
ratio  = volMed > 0 ? volNow / volMed : na

// ── Latched pause (1h cooldown — avoids threshold flirt) ───────────────────────
var bool latchedPause = false
var int  pauseStartBar = na

rawPause = not na(ratio) and ratio >= pauseRatio

if rawPause and not latchedPause
    latchedPause := true
    pauseStartBar := bar_index

if latchedPause
    barsHeld = bar_index - pauseStartBar
    canResume = barsHeld >= cooldownBars and not na(ratio) and ratio < resumeRatio
    if canResume
        latchedPause := false
        pauseStartBar := na

// ── Plot ─────────────────────────────────────────────────────────────────────
ratioColor = latchedPause ? color.red
           : not na(ratio) and ratio >= pauseRatio ? color.orange
           : color.teal

plot(ratio, "vol_ratio", color=ratioColor, linewidth=2)
plot(showGuides ? pauseRatio  : na, "Pause",  color=color.new(color.red,   40), style=plot.style_linebr)
plot(showGuides ? resumeRatio : na, "Resume", color=color.new(color.green, 50), style=plot.style_linebr)
plot(showGuides ? 1.0 : na, "Normal (1×)", color=color.new(color.gray, 60), style=plot.style_circles)

bgcolor(showBg and latchedPause ? color.new(color.red, 88) : na, title="Pause zone (latched)")

// ── Alerts ───────────────────────────────────────────────────────────────────
alertcondition(rawPause and not rawPause[1], title="Grid vol_ratio pause",
     message="vol_ratio crossed pause threshold — latched for {{input.cooldownHours}}h min")
alertcondition(latchedPause[1] and not latchedPause, title="Grid vol_ratio resume",
     message="vol_ratio cooldown complete and below resume threshold")

// ── Info table ───────────────────────────────────────────────────────────────
var table info = table.new(position.bottom_right, 1, 5, bgcolor=color.new(color.black, 80), border_width=1)

if showInfo and barstate.islast
    held = latchedPause ? str.tostring(bar_index - pauseStartBar) + "/" + str.tostring(cooldownBars) + " bars" : "—"
    table.cell(info, 0, 0, "Grid vol_ratio", text_color=color.white, text_size=size.small)
    table.cell(info, 0, 1, "Chart: " + timeframe.period + "  |  σ bars: " + str.tostring(volLb), text_color=color.silver, text_size=size.tiny)
    table.cell(info, 0, 2, "Median bars: " + str.tostring(medLb) + "  (~" + str.tostring(medWindowHours, "#") + "h)", text_color=color.silver, text_size=size.tiny)
    table.cell(info, 0, 3, "Now: " + str.tostring(ratio, "#.##") + "×  |  latched: " + (latchedPause ? "YES" : "no"), text_color=ratioColor, text_size=size.tiny)
    table.cell(info, 0, 4, "Cooldown: " + held, text_color=color.silver, text_size=size.tiny)
